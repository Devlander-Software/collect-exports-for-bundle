{
  "name": "collectbyexports",
  "version": "0.1.54",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/typings/index.d.ts",
  "type": "commonjs",
  "files": [
    "dist"
  ],
  "description": "Easily collect all exports from a directory to your index file for bundling.",
  "author": {
    "name": "Landon W. Johnson",
    "url": "https://landonjohnson.dev"
  },
  "keywords": [
    "export and bundle",
    "landon johnson",
    "design system",
    "rollup",
    "storybook",
    "typescript",
    "landon w johnson",
    "devlander",
    "techwithlandon"
  ],
  "scripts": {
    "prepare": "yarn run build",
    "check-submodules": "node -e \"require('os').platform() === 'win32' ? require('child_process').execSync('powershell -ExecutionPolicy Bypass -File ./check-submodules/check-submodules.ps1', {stdio: 'inherit'}) : require('child_process').execSync('bash ./check-submodules/check-submodules.sh', {stdio: 'inherit'});\"",
    "check-packages": "npx check-package-dependencies",
    "docs": "typedoc",
    "test": "yarn run link-packages && yarn run check-submodules && node ./example/bootstrap.cjs && yarn run  jest --verbose --no-cache --coverage",
    "link-packages": "yarn run format && yarn run typecheck && yarn run build && node ./yarn-link-handler.js",
    "test:snaps": "jest --updateSnapshot",
    "patch": "yarn version --new-version patch",
    "minor": "yarn version --new-version minor",
    "major": "yarn version --new-version major",
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "clean": "rm -rf dist node_modules/.cache",
    "reorganize": "node scripts/reorganize-structure.js",
    "update-imports": "node scripts/update-imports.js",
    "optimize": "node scripts/optimize-build.js",
    "benchmark": "node scripts/benchmark.js",
    "analyze-performance": "node scripts/performance-analysis.js"
  },
  "license": "MIT",
  "bin": {
    "collectbyexports": "./dist/cjs/cli.js",
    "cbe": "./dist/cjs/cli.js"
  },
  "engines": {
    "node": ">=14"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "picocolors": "^1.0.0",
    "source-map": "^0.7.4",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "@babel/core": "^7.22.17",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-runtime": "^7.22.15",
    "@babel/preset-env": "^7.22.15",
    "@babel/preset-typescript": "^7.22.15",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@swc/core": "^1.3.94",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.12",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.8.0",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.4.2",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-sort-imports-es6-autofix": "^0.6.0",
    "prettier": "^3.0.3",
    "rollup": "^3.29.1",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "rollup-plugin-terser": "^7.0.2",
    "typedoc": "^0.25.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Devlander-Software/collectexports.git"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}

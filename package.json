{
  "name": "@devlander/collect-exports-for-bundle",
  "version": "2.0.0-beta.1",
  "description": "Generate comprehensive export files for TypeScript/JavaScript projects with Rollup compatibility",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "bin": {
    "collect-exports": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js",
      "require": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:prod": "rollup -c rollup.config.prod.mjs",
    "dev": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build && npm run audit:prod && npm run size:check",
    "docs": "typedoc",
    "docs:build": "npm run docs && npm run docs:optimize",
    "docs:optimize": "node scripts/optimize-docs.js",
    "docs:serve": "npx http-server docs -p 8080 -o",
    "audit:prod": "npm audit --omit=dev",
    "size:check": "node scripts/check-bundle.mjs",
    "release": "semantic-release"
  },
  "keywords": [
    "typescript",
    "javascript",
    "exports",
    "rollup",
    "webpack",
    "bundler",
    "auto-export",
    "barrel-exports",
    "module-exports"
  ],
  "author": "DevLander",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devlander/collect-exports-for-bundle.git"
  },
  "bugs": {
    "url": "https://github.com/devlander/collect-exports-for-bundle/issues"
  },
  "homepage": "https://github.com/devlander/collect-exports-for-bundle#readme",
  "engines": {
    "node": ">=18.18"
  },
  "peerDependencies": {
    "rollup": ">=3.0.0",
    "typescript": ">=4.5.0"
  },
  "dependencies": {
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.2",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "http-server": "^14.1.1",
    "jest": "^29.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "semantic-release": "^24.2.7",
    "ts-jest": "^29.0.0",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.10",
    "typedoc-theme-hierarchy": "^6.0.0",
    "typescript": "^5.0.0"
  }
}
